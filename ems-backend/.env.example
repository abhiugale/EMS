# Database Settings (TimescaleDB / PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=emsdb
DB_USER=postgres
DB_PASSWORD=postgres

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO Settings (S3-compatible Object Storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ems-bucket

# JWT Authentication Settings
JWT_SECRET=supersecretjwtkeyforprodemsapp1234567890!
JWT_EXPIRY_MS=3600000
JWT_REFRESH_EXPIRY_MS=86400000

# Spring Settings
SPRING_PROFILES_ACTIVE=dev

# ML Service Settings
ML_SERVICE_URL=http://localhost:8001

# Alert Notification Settings (WhatsApp via Meta API, SMS via Twilio)
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
TWILIO_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM=your_twilio_from_phone_number_here

# Security Settings
CORS_ORIGINS=http://localhost:5173
