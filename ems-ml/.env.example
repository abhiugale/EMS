# Application
APP_NAME="EMS ML Service"
APP_VERSION="1.0.0"
DEBUG=false

# Database (TimescaleDB / PostgreSQL 16)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/emsdb
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Model persistence
MODEL_DIR=saved_models
MODEL_RETRAIN_INTERVAL_HOURS=24

# Anomaly detection
ANOMALY_CONTAMINATION=0.05
ANOMALY_SCORE_THRESHOLD=-0.2
LSTM_SEQUENCE_LENGTH=24
LSTM_EPOCHS=50
LSTM_BATCH_SIZE=32
LSTM_LATENT_DIM=64

# Forecasting
FORECAST_HORIZON_HOURS=24
PROPHET_SEASONALITY_MODE=multiplicative
XGBOOST_N_ESTIMATORS=200

# Predictive maintenance
RF_N_ESTIMATORS=100
RF_MAX_DEPTH=10
MAINTENANCE_ALERT_THRESHOLD=0.7
